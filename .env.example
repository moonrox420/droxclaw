# Required: Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: Webhook URL (if set, webhook mode; otherwise polling)
WEBHOOK_URL=

# Required for LLM: Ollama cloud (or self-hosted) API
OLLAMA_API_BASE=https://api.ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5-coder:14b-instruct-q6_K

# Optional: GitHub integration (list repos, create/get issues)
GITHUB_TOKEN=

# Optional: Email integration (send email)
SMTP_SERVER=smtp-mail.outlook.com
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# Optional: Admin chat ID for heartbeat messages
ADMIN_CHAT_ID=

# Optional: HTTP port when running with webhook (default 8000)
PORT=8000
